        "./src/features/checkout/components/Checkout/*"
      ],
      "@/src/components/CreaetStore/*": [
        "./src/features/store-creation/components/CreaetStore/*"
      ],
      "@/src/components/Dashboard/*": [
        "./src/features/dashboard/components/*"
      ],
      "@/src/components/FeaturesSection/*": [
        "./src/features/home/components/FeaturesSection/*"
      ],
      "@/src/components/Filters/*": ["./src/features/shop/components/Filters/*"],
      "@/src/components/FlashDeals/*": [
        "./src/features/home/components/FlashDeals/*"
